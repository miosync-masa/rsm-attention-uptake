    "validation_status": "Initial draft — requires native-speaker validation per language",
    "notes": [
      "Acknowledgment: low-information positive uptake markers",
      "Repair: clarification requests; contingent but non-positive, kept separate from R+ depth",
      "Items are matched case-insensitively with light punctuation stripping",
      "Multi-word items are matched as substring within the utterance text",
      "CJK languages (Japanese, Mandarin) use character-based matching",
      "Latin-script languages (English, Spanish) use word-boundary matching"
    ],
    "languages_covered": ["english", "english-uk", "japanese", "spanish", "mandarin"],
    "languages_excluded_paper2": ["korean", "russian", "indonesian"]
  },

